		</band>
		<!-- Band 2: TEST - simple single-line test (parent markers, culture root tests, leftover singles) -->
		<band height="17" splitType="Prevent">
			<printWhenExpression><![CDATA["TEST".equals($F{bacterioRowType}) && !$F{isBacterioParentTest}]]></printWhenExpression>
			<textField textAdjust="StretchHeight" isBlankWhenNull="true">
				<reportElement x="15" y="1" width="200" height="15" isRemoveLineWhenBlank="true" isPrintWhenDetailOverflows="true" uuid="0ae78609-2e0c-405e-a9a4-efdf6d998969"/>
