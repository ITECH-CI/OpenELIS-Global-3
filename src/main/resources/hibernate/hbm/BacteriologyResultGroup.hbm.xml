<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class
        name="org.openelisglobal.bacteriology.valueholder.BacteriologyResultGroup"
        table="bacteriology_result_group" schema="clinlims">
        <id name="id" type="java.lang.Integer">
            <column name="id" precision="10" scale="0" />
            <generator class="sequence">
                <param name="sequence">clinlims.bacteriology_result_group_seq</param>
            </generator>
        </id>
        <property name="analysisId" type="java.lang.Integer">
            <column name="analysis_id" precision="10" scale="0"
                not-null="true" />
        </property>
        <property name="groupType" type="string">
            <column name="group_type" length="50" not-null="true" />
        </property>
        <property name="groupNumber" type="java.lang.Integer">
            <column name="group_number" precision="10" scale="0" />
        </property>
        <property name="parentGroupId" type="java.lang.Integer">
            <column name="parent_group_id" precision="10" scale="0" />
        </property>
        <property name="testId" type="java.lang.Integer">
            <column name="test_id" precision="10" scale="0" />
        </property>
        <property name="displayOrder" type="java.lang.Integer">
            <column name="display_order" precision="10" scale="0" />
        </property>
        <property name="isActive" type="java.lang.Boolean">
            <column name="is_active" />
        </property>
        <property name="createdDate" type="timestamp">
            <column name="created_date" length="29" />
        </property>
        <property name="lastupdated" type="timestamp">
            <column name="lastupdated" length="29" />
        </property>
    </class>
</hibernate-mapping>
