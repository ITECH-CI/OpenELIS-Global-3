<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="org.openelisglobal.bacteriology.valueholder.BacteriologyOrganism"
           table="bacteriology_organism" schema="clinlims">
        <id name="id" type="java.lang.Integer">
            <column name="id" precision="10" scale="0" />
            <generator class="sequence">
                <param name="sequence">clinlims.bacteriology_organism_seq</param>
            </generator>
        </id>
        <property name="resultGroupId" type="java.lang.Integer">
            <column name="result_group_id" precision="10" scale="0" not-null="true" />
        </property>
        <property name="organismNumber" type="java.lang.Integer">
            <column name="organism_number" precision="10" scale="0" not-null="true" />
        </property>
        <property name="organismType" type="string">
            <column name="organism_type" length="20" />
        </property>
        <property name="organismNameDictId" type="java.lang.Integer">
            <column name="organism_name_dict_id" precision="10" scale="0" />
        </property>
        <property name="organismNameText" type="string">
            <column name="organism_name_text" length="255" />
        </property>
        <property name="gramType" type="string">
            <column name="gram_type" length="100" />
        </property>
        <property name="groupingMode" type="string">
            <column name="grouping_mode" length="100" />
        </property>
        <property name="capsulePresence" type="java.lang.Boolean">
            <column name="capsule_presence" />
        </property>
        <property name="otherCharacteristics" type="text">
            <column name="other_characteristics" />
        </property>
        <property name="isActive" type="java.lang.Boolean">
            <column name="is_active" />
        </property>
        <property name="lastupdated" type="timestamp">
            <column name="lastupdated" length="29" />
        </property>
    </class>
</hibernate-mapping>
