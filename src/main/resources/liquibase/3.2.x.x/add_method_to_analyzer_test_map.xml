<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

	<property name="now" value="now()" dbms="postgresql" />

	<changeSet author="pkomena" id="add-method-to-analyzer-test-map-1">
		<preConditions onFail="MARK_RAN">
			<not>
				<columnExists schemaName="clinlims"
					tableName="analyzer_test_map" columnName="method_id" />
			</not>
		</preConditions>
		<comment>Ajouter la colonne method_id à analyzer_test_map pour associer une méthode d'analyse à chaque mapping analyser-test</comment>
		<addColumn schemaName="clinlims" tableName="analyzer_test_map">
			<column name="method_id" type="numeric(10,0)">
				<constraints nullable="true"
					foreignKeyName="fk_analyzer_test_map_method"
					references="clinlims.method(id)" />
			</column>
		</addColumn>
	</changeSet>

</databaseChangeLog>
