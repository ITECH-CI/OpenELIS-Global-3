<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026012601" author="pkomena">
        <comment>Add test_id column to bacteriology_result_group table to link culture/organism groups to specific tests</comment>

        <addColumn tableName="bacteriology_result_group" schemaName="clinlims">
            <column name="test_id" type="INTEGER">
                <constraints nullable="true" />
            </column>
        </addColumn>

        <addForeignKeyConstraint
            baseTableName="bacteriology_result_group"
            baseColumnNames="test_id"
            baseTableSchemaName="clinlims"
            constraintName="fk_bacteriology_result_group_test"
            referencedTableName="test"
            referencedColumnNames="id"
            referencedTableSchemaName="clinlims"
            onDelete="SET NULL"/>

        <createIndex indexName="idx_bacteriology_result_group_test_id"
                     tableName="bacteriology_result_group"
                     schemaName="clinlims">
            <column name="test_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
