	<property name="now" value="now()" dbms="postgresql" />
	<changeSet author="CIV developer"
		id="add-routine-bacteriology-test-section">
		<preConditions onFail="CONTINUE">
			<sqlCheck expectedResult="0">select count(*) from
				clinlims.test_section where name = 'Routine Bacteriology';
			</sqlCheck>
		</preConditions>
		<comment>Add routine Bacteriology test_section</comment>
		<insert schemaName="clinlims" tableName="localization">
			<column name="id" valueSequenceNext="localization_seq" />
			<column name="lastupdated" valueComputed="${now}" />
			<column name="description"
				value="Routine Bacteriology test section" />
			<column name="english" value="Routine Bacteriology" />
			<column name="french" value="Bactériologie Classique" />
		</insert>
		<insert tableName="test_section" schemaName="clinlims">
			<column name="id" valueSequenceNext="test_section_seq" />
			<column name="name" value="Routine Bacteriology" />
			<column name="description"
				value="Routine Bacteriology Department" />
			<column name="is_external" value="N" />
			<column name="lastupdated" valueComputed="${now}" />
			<column name="sort_order" value="80" />
			<column name="is_active" value="Y" />
			<column name="name_localization_id"
				valueComputed="(select id from localization where description = 'Routine Bacteriology test section' and english = 'Routine Bacteriology' limit 1)" />
			<column name="display_key"
				value="testsection.RoutineBacteriology" />
		</insert>
	</changeSet>

