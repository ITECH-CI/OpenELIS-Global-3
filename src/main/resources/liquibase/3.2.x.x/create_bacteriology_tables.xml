<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Create bacteriology_result_group table -->
    <changeSet author="CIV developer Group" id="2026011100">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="bacteriology_result_group" schemaName="clinlims"/>
            </not>
        </preConditions>

        <createSequence sequenceName="bacteriology_result_group_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>

        <createTable tableName="bacteriology_result_group" schemaName="clinlims">
            <column name="id" type="INTEGER" defaultValueSequenceNext="bacteriology_result_group_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="analysis_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="group_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="group_number" type="INTEGER"/>
            <column name="parent_group_id" type="INTEGER"/>
            <column name="display_order" type="INTEGER"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="sys_user_id" type="INTEGER"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_bact_group_analysis"
            baseTableName="bacteriology_result_group"
            baseTableSchemaName="clinlims"
            baseColumnNames="analysis_id"
            referencedTableName="analysis"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="fk_bact_group_parent"
            baseTableName="bacteriology_result_group"
            baseTableSchemaName="clinlims"
            baseColumnNames="parent_group_id"
            referencedTableName="bacteriology_result_group"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="fk_bact_group_user"
            baseTableName="bacteriology_result_group"
            baseTableSchemaName="clinlims"
            baseColumnNames="sys_user_id"
            referencedTableName="system_user"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>

        <createIndex indexName="idx_bact_group_analysis"
                     tableName="bacteriology_result_group" schemaName="clinlims">
            <column name="analysis_id"/>
        </createIndex>

        <createIndex indexName="idx_bact_group_parent"
                     tableName="bacteriology_result_group" schemaName="clinlims">
            <column name="parent_group_id"/>
        </createIndex>
    </changeSet>

    <!-- Create bacteriology_organism table -->
    <changeSet author="CIV developer Group" id="2026011101">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="bacteriology_organism" schemaName="clinlims"/>
            </not>
        </preConditions>

        <createSequence sequenceName="bacteriology_organism_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>

        <createTable tableName="bacteriology_organism" schemaName="clinlims">
            <column name="id" type="INTEGER" defaultValueSequenceNext="bacteriology_organism_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="result_group_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="organism_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="organism_type" type="VARCHAR(20)"/>
            <column name="organism_name_dict_id" type="INTEGER"/>
            <column name="organism_name_text" type="VARCHAR(255)"/>
            <column name="gram_type" type="VARCHAR(100)"/>
            <column name="grouping_mode" type="VARCHAR(100)"/>
            <column name="capsule_presence" type="BOOLEAN"/>
            <column name="other_characteristics" type="TEXT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_bact_organism_group"
            baseTableName="bacteriology_organism"
            baseTableSchemaName="clinlims"
            baseColumnNames="result_group_id"
            referencedTableName="bacteriology_result_group"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="fk_bact_organism_dict"
            baseTableName="bacteriology_organism"
            baseTableSchemaName="clinlims"
            baseColumnNames="organism_name_dict_id"
            referencedTableName="dictionary"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>

        <createIndex indexName="idx_bact_organism_group"
                     tableName="bacteriology_organism" schemaName="clinlims">
            <column name="result_group_id"/>
        </createIndex>
    </changeSet>

    <!-- Create bacteriology_antibiogram table -->
    <changeSet author="CIV developer Group" id="2026011102">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="bacteriology_antibiogram" schemaName="clinlims"/>
            </not>
        </preConditions>

        <createSequence sequenceName="bacteriology_antibiogram_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>

        <createTable tableName="bacteriology_antibiogram" schemaName="clinlims">
            <column name="id" type="INTEGER" defaultValueSequenceNext="bacteriology_antibiogram_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organism_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="antibiotic_dict_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="result" type="VARCHAR(1)">
                <constraints nullable="false"/>
            </column>
            <column name="diameter_mm" type="DECIMAL(5,2)"/>
            <column name="mic_value" type="VARCHAR(50)"/>
            <column name="interpretation_comment" type="TEXT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_bact_atb_organism"
            baseTableName="bacteriology_antibiogram"
            baseTableSchemaName="clinlims"
            baseColumnNames="organism_id"
            referencedTableName="bacteriology_organism"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="fk_bact_atb_dict"
            baseTableName="bacteriology_antibiogram"
            baseTableSchemaName="clinlims"
            baseColumnNames="antibiotic_dict_id"
            referencedTableName="dictionary"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>

        <createIndex indexName="idx_bact_atb_organism"
                     tableName="bacteriology_antibiogram" schemaName="clinlims">
            <column name="organism_id"/>
        </createIndex>
    </changeSet>

    <!-- Create bacteriology_conditional_test table -->
    <changeSet author="CIV developer Group" id="2026011103">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="bacteriology_conditional_test" schemaName="clinlims"/>
            </not>
        </preConditions>

        <createSequence sequenceName="bacteriology_conditional_test_seq" schemaName="clinlims" startValue="1" incrementBy="1"/>

        <createTable tableName="bacteriology_conditional_test" schemaName="clinlims">
            <column name="id" type="INTEGER" defaultValueSequenceNext="bacteriology_conditional_test_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="parent_test_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="parent_result_value" type="VARCHAR(255)"/>
            <column name="child_test_ids" type="TEXT"/>
            <column name="condition_type" type="VARCHAR(50)"/>
            <column name="display_order" type="INTEGER"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_bact_cond_parent_test"
            baseTableName="bacteriology_conditional_test"
            baseTableSchemaName="clinlims"
            baseColumnNames="parent_test_id"
            referencedTableName="test"
            referencedTableSchemaName="clinlims"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
